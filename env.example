# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (cloud or local)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Prisma)
# For local Docker Postgres in docker-compose.yml, this default works.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobranger_dev?schema=public
# Optional separate direct connection string for Prisma CLI (migrate/db push/introspection)
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/jobranger_dev?schema=public

# Integration tests (RLS simulation). Requires running:
# - npx prisma db execute --file prisma/ci-supabase-compat.sql
# - npx prisma db execute --file prisma/rls-policies.sql
RLS_TEST_DATABASE_URL=postgresql://app_user:app@localhost:5432/jobranger_dev?schema=public

# AI / Jobs API
GEMINI_API_KEY=
AF_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_ALLOWED_PRICE_IDS=

# Upstash (distributed rate limiting + integration tests)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: enables debug/admin gating in dev
DEBUG_EMAIL=


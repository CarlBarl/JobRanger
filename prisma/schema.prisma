generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  // Use Supabase Auth user id as the primary key.
  id        String   @id
  email     String   @unique
  role      UserRole @default(USER)
  tier      UserTier @default(FREE)
  country   String?  @db.Char(2)
  name                String?
  onboardingCompleted Boolean  @default(false)
  dashboardGuidePromptedAt  DateTime?
  dashboardGuideCompletedAt DateTime?
  dashboardGuideDismissedAt DateTime?
  dashboardGuideLastStartedAt DateTime?
  dashboardGuideBonusGenerateLetterUsedAt DateTime?
  onboardingGuideResetAt    DateTime?
  onboardingGuideLastCompletedAt DateTime?
  proActivatedAt DateTime?
  proOnboardingDismissedAt DateTime?
  proOnboardingCompletedAt DateTime?
  proOnboardingCvStudioVisitedAt DateTime?
  letterGuidanceDefault     String?  @db.Text
  createdAt           DateTime @default(now())

  documents        Document[]
  savedJobs        SavedJob[]
  generatedLetters GeneratedLetter[]
  usageEvents      UsageEvent[]
  subscriptions    Subscription[]
}

enum UserTier {
  FREE
  PRO
}

enum UserRole {
  USER
  ADMIN
}

enum DocumentType {
  cv
  personal_letter
}

enum UsageEventType {
  GENERATE_LETTER
  SKILLS_EXTRACT
  SKILLS_BATCH
  CV_FEEDBACK
  CV_EDIT
}

model Document {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          DocumentType
  fileUrl       String?
  parsedContent String?      @db.Text
  skills        Json?
  createdAt     DateTime     @default(now())

  @@index([userId])
  @@index([userId, type])
}

model SavedJob {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  afJobId String
  notes   String?
  savedAt DateTime @default(now())

  // Cached from AF API at save time
  headline   String?
  employer   String?
  location   String?
  occupation String?
  deadline   String?
  webpageUrl String?

  letters GeneratedLetter[]

  @@unique([userId, afJobId])
  @@index([userId])
}

model GeneratedLetter {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedJobId String?
  savedJob   SavedJob? @relation(fields: [savedJobId], references: [id], onDelete: SetNull)
  afJobId    String
  jobTitle   String?
  guidanceUsed String?  @db.Text
  content    String    @db.Text
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([afJobId])
}

model UsageEvent {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      UsageEventType
  createdAt DateTime       @default(now())

  @@index([userId, type, createdAt])
}

enum BillingProvider {
  STRIPE
}

enum SecurityEventCategory {
  AUTH
  ADMIN
  BILLING
  RATE_LIMIT
  SYSTEM
}

enum SecurityEventSeverity {
  INFO
  WARN
  ERROR
  CRITICAL
}

model Subscription {
  id                   String          @id @default(cuid())
  userId               String
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider             BillingProvider @default(STRIPE)
  stripeCustomerId     String          @unique
  stripeSubscriptionId String?         @unique
  status               String
  priceId              String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([userId, provider])
  @@index([stripeSubscriptionId])
}

model BillingEvent {
  id         String          @id @default(cuid())
  provider   BillingProvider @default(STRIPE)
  eventId    String          @unique
  type       String
  receivedAt DateTime        @default(now())
  processedAt DateTime?
}

model SecurityEvent {
  id          String                @id @default(cuid())
  category    SecurityEventCategory
  severity    SecurityEventSeverity @default(INFO)
  eventType   String
  actorUserId String?
  targetUserId String?
  requestId   String?
  ipAddress   String?
  message     String?
  metadata    Json?
  createdAt   DateTime              @default(now())

  @@index([category, createdAt])
  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
}


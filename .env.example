# JobMatch Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# SUPABASE (https://supabase.com)
# ===========================================
# Get these from your Supabase project settings

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anonymous key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key (secret - server only!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here


# ===========================================
# DATABASE
# ===========================================
# PostgreSQL connection string from Supabase

DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres


# ===========================================
# ARBETSFÖRMEDLINGEN API (optional)
# ===========================================
# Only needed for job search endpoints.
# Get your API key from: https://apirequest.jobtechdev.se

AF_API_KEY=


# ===========================================
# GEMINI AI (https://makersuite.google.com)
# ===========================================
# Get your API key from: https://makersuite.google.com/app/apikey

GEMINI_API_KEY=your_gemini_api_key_here


# ===========================================
# APP SETTINGS
# ===========================================

# Your app URL (change for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development
